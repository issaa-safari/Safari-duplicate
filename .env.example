# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WhatsApp Business (required for the WhatsApp lead-capture webhook) ───────
# The webhook rejects all POSTs with 401 until WHATSAPP_APP_SECRET is set.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── Google Maps Platform (optional — geo enrichment no-ops when unset) ───────
# The proposal itinerary map works without this (OpenStreetMap tiles +
# coordinates parsed from pasted Google Maps links). Setting a key enables the
# server-side enrichment in lib/google-places.ts (geocoding, place photos).
GOOGLE_MAPS_API_KEY=
# Key for "Places API (New)" text search (admin content forms' Google Maps
# lookup) and "Routes API" road distances — enable BOTH APIs on this key in
# Google Cloud. Server-only; falls back to GOOGLE_MAPS_API_KEY when unset.
GOOGLE_PLACES_API_KEY=

# ── AI drafting via Anthropic (optional — the "Describe the trip" intake in ──
# the Trip Builder no-ops with a clear message when unset; the rest works). ──
# Used only to DRAFT a trip skeleton from a free-text enquiry; pricing is always
# computed in code, never by the model.
ANTHROPIC_API_KEY=

# ── Conversational intake MCP endpoint (/api/mcp) for the Cowork safari-intake ──
# plugin. Claude conducts the enquiry interview and calls create_safari_draft to
# create a DRAFT quote + request (never prices, never sends). Required for the
# endpoint to accept writes — the same token is set where Cowork runs.
MCP_INTAKE_TOKEN=
# Absolute admin base URL used to build the review link returned by the tool,
# e.g. https://app.safariadventureriders.com
APP_BASE_URL=

# ── Email via Resend (optional — email silently no-ops when unset) ───────────
RESEND_API_KEY=
# Verified sender; defaults to "Safari Adventure Riders <no-reply@safariadventureriders.com>"
EMAIL_FROM=
# Where admin alerts go; defaults to the address in lib/site.ts
ADMIN_NOTIFICATION_EMAIL=
