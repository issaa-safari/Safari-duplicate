# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WhatsApp Business (required for the WhatsApp lead-capture webhook) ───────
# The webhook rejects all POSTs with 401 until WHATSAPP_APP_SECRET is set.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── Email via Resend (optional — email silently no-ops when unset) ───────────
RESEND_API_KEY=
# Verified sender; defaults to "Safari Adventure Riders <no-reply@safariadventureriders.com>"
EMAIL_FROM=
# Where admin alerts go; defaults to the address in lib/site.ts
ADMIN_NOTIFICATION_EMAIL=
