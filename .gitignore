# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Claude Code machine-local settings (impeccable hook manifest)
.claude/settings.local.json
# impeccable live-mode session state (config.json stays tracked)
.impeccable/live/sessions/

# Android APK build (local only — keystore is a secret)
/apkbuild/
/apk-src/
*.apk
*.keystore

# Carousel generator — rendered output + render temp files (regenerable)
/tools/carousel/out/
/tools/carousel/template/.render-*.html
