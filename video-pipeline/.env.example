# Copy this file to .env and fill in your values.  .env is gitignored — never commit it.

# --- Telegram (Stage 1) ---
# Get these from https://my.telegram.org  ->  API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session name; a <name>.session file is created on first login and reused after.
TELEGRAM_SESSION=safari_ingest

# --- Blotato (Stage 5) ---
BLOTATO_API_KEY=
